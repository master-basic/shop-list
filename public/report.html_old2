<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Report</title>
    <style>
        /* ...existing styles... */
        table { width: 90%; margin: 20px auto; border-collapse: collapse; }
        th, td { padding: 8px; border: 1px solid #ccc; text-align: left; }
        .date-range, .buttons { text-align: center; margin: 20px; }
    </style>
</head>
<body>
    <div class="date-range">
        <label>From: <input type="date" id="start-date"></label>
        <label>To: <input type="date" id="end-date"></label>
        <button onclick="filterReport()">Filter</button>
    </div>
    <table id="report-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Date Added</th>
                <th>Bought Date</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
                <th>Bought By</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="report-list">
            <!-- ...existing table rows generated by report.js... -->
        </tbody>
        <tfoot id="report-summary">
            <!-- Summary rows will be injected here -->
        </tfoot>
    </table>
    <div id="total-amount" style="text-align:center;">
        Total: AZN <span id="total-value"></span>
    </div>
    <div class="buttons">
        <button onclick="printReport()">Print Report</button>
        <button onclick="window.location.href='index2.html'">Back to Main Page</button>
    </div>
    <div id="buyer-summary" style="position: fixed; bottom: 10px; left: 10px; background: #f8f8f8; padding: 10px; border: 1px solid #ddd;">
        <!-- Buyer summary injected by report.js -->
    </div>
    <script src="report.js"></script>
    <script>
        function filterReport(){
            // Implement filtering based on date range selection
            const start = document.getElementById('start-date').value;
            const end = document.getElementById('end-date').value;
            console.log("Filtering report from", start, "to", end);
            // You may extend report.js to use these values for filtering
        }
        function printReport(){
            window.print();
        }
    </script>
</body>
</html>
